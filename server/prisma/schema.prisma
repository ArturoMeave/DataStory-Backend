generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum Role {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}


model Workspace {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  users     User[]
  invitations Invitation[]
  snapshots Snapshot[]
}


model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String?
  name        String?
  createdAt   DateTime @default(now())
  sessions    Session[]

  role        Role     @default(VIEWER)
  
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  googleId    String?  @unique

  twoFactorSecret    String?
  isTwoFactorEnabled Boolean @default(false)
  twoFactorFrequency String  @default("always")

  alertConfig UserAlertConfig?
  uploadedSnapshots Snapshot[]

  shopifyConnection ShopifyConnection?
  shopifyOrders    ShopifyCachedOrder[]
  shopifyProducts  ShopifyCachedProduct[]
  shopifyCustomers ShopifyCachedCustomer[]
}


model Snapshot {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  totalRevenue  Float
  totalExpenses Float
  netProfit     Float
  periodCount   Int
  anomalyCount  Int
  goalAmount    Float?
  aiSummary     String?
  recentPeriods Json

  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  uploadedById  String?
  uploadedBy    User?     @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
}


model UserAlertConfig {
  id                  String  @id @default(uuid())
  userId              String  @unique
  email               String
  enableAnomalyAlerts Boolean @default(true)
  enableDailyDigest   Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  device    String
  browser   String
  ip        String
  createdAt DateTime @default(now())
  lastUsed  DateTime @default(now())
  isActive  Boolean  @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invitation {
  id          String   @id @default(uuid())
  code        String   @unique // El código secreto (ej. AX92-KPL1)
  workspaceId String   // A qué empresa pertenece la invitación
  role        Role     @default(EDITOR) // Qué rol se le dará al usuario
  createdAt   DateTime @default(now())
  expiresAt   DateTime @default(now())
  
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model ShopifyConnection {
  id           String   @id @default(uuid())
  shop         String   @unique
  accessToken  String
  createdAt    DateTime @default(now())
  updateAt     DateTime @updatedAt
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
}

model ShopifyCachedOrder {
  id                String   @id
  userId            String
  orderNumber       String
  customerName      String
  date              DateTime
  total             Float
  financialStatus   String
  fulfillmentStatus String
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ShopifyCachedProduct {
  id          String   @id
  userId      String
  title       String
  image       String?
  status      String
  inventory   Int
  price       Float
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ShopifyCachedCustomer {
  id          String   @id
  userId      String
  name        String
  email       String
  ordersCount Int
  totalSpent  Float
  verified    Boolean
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}